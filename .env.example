# Hosted Next.js application
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
NEXT_PUBLIC_APP_URL="https://your-site.netlify.app"
BASE_AGENCY_API_KEY="generate-a-long-random-value"
ZKTECO_SYNC_SECRET="generate-a-long-random-value"
ZK_BRIDGE_SECRET="generate-a-long-random-value"
BRIDGE_SECRET="use-the-same-value-as-zk-bridge-secret"
ZK_BRIDGE_ALLOWED_DEVICE_SERIALS=""

# Local ZKTeco bridge only; do not add these to Netlify
ZK_BRIDGE_LOCAL_PORT="8081"
ZK_BRIDGE_LOCAL_HOST="0.0.0.0"
WEBSITE_ATTENDANCE_PUSH_URL="https://your-site.netlify.app/api/zkteco/attendance/push"

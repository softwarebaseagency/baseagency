  model        String?
  location     String?
  isActive     Boolean         @default(true) @map("is_active")
  lastSeenAt   DateTime?       @map("last_seen_at")
  logs         AttendanceLog[]
  syncLogs     AttendanceSyncLog[]
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  @@index([serialNumber])
  @@index([isActive])

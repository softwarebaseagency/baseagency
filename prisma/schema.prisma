model AttendanceEmployee {
  id           String          @id @default(cuid())
  employeeCode String          @unique @map("employee_code")
  name         String
  department   String?
  position     String?
  email        String?
  phone        String?
  isActive     Boolean         @default(true) @map("is_active")
  logs         AttendanceLog[]
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  @@index([employeeCode])
  @@index([name])
  @@index([isActive])
  @@map("employees")
}

model AttendanceLog {
  id             String             @id @default(cuid())
  employeeId     String             @map("employee_id")
  deviceId       String             @map("device_id")
  employeeCode   String             @map("employee_code")
  checkInTime    DateTime?          @map("check_in_time")
  checkOutTime   DateTime?          @map("check_out_time")
  attendanceDate DateTime           @map("attendance_date") @db.Date
  rawTimestamp   DateTime           @map("raw_timestamp")
  status         AttendanceStatus   @default(PRESENT)
  source         AttendanceSource   @default(ZKTECO_ADMS)
  rawPayload     Json?              @map("raw_payload")
  uniqueKey      String             @unique @map("unique_key")
  employee       AttendanceEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  device         AttendanceDevice   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  @@index([employeeCode])
  @@index([attendanceDate])
  @@index([rawTimestamp])
  @@index([status])
  @@map("attendance_logs")
}

model AttendanceSyncLog {
  id         String               @id @default(cuid())
  deviceId   String?              @map("device_id")
  syncType   String               @map("sync_type")
  status     AttendanceSyncStatus
  message    String
  payload    Json?
  startedAt  DateTime             @map("started_at")
  finishedAt DateTime?            @map("finished_at")
  device     AttendanceDevice?    @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  createdAt  DateTime             @default(now()) @map("created_at")

  @@index([deviceId])
  @@index([status])
  @@index([startedAt])
  @@map("sync_logs")
}

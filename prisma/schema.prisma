generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CustomerStatus {
  NEW
  CONTACTED
  QUALIFIED
  CUSTOMER
  LOST
}

enum ExpenseType {
  DAILY
  MONTHLY_RECURRING
  ONE_TIME
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum SaleStatus {
  LEAD
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TeamStatus {
  ACTIVE
  INACTIVE
}

enum WorkType {
  FULL_TIME
  PART_TIME
  CONTRACT
  FREELANCE
}

enum TeamPaymentType {
  SALARY
  BONUS
  COMMISSION
  ADVANCE
}

enum SyncStatus {
  CREATED
  UPDATED
  FAILED
}

enum ZktecoDeviceStatus {
  ONLINE
  OFFLINE
  UNKNOWN
}

enum ZktecoSyncStatus {
  SUCCESS
  DEVICE_OFFLINE
  WRONG_IP
  TIMEOUT
  API_TOKEN_INVALID
  DATABASE_ERROR
  PARTIAL_SYNC
  FAILED
  PENDING
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
}

enum AttendanceSource {
  ZKTECO_ADMS
  MANUAL
  IMPORT
}

enum AttendanceSyncStatus {
  SUCCESS
  FAILED
  PARTIAL
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id              String         @id @default(cuid())
  fullName        String
  phone           String?
  whatsapp        String?
  email           String?
  address         String?
  source          String?
  serviceInterest String?
  status          CustomerStatus @default(NEW)
  notes           String?
  sales           Sale[]
  syncLogs        WebsiteSyncLog[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([phone])
  @@unique([email])
  @@index([fullName])
  @@index([status])
}

model Expense {
  id            String        @id @default(cuid())
  title         String
  category      String
  amount        Decimal       @db.Decimal(12, 2)
  date          DateTime
  type          ExpenseType   @default(DAILY)
  paymentStatus PaymentStatus @default(UNPAID)
  paidBy        String?
  notes         String?
  attachment    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([date])
  @@index([category])
  @@index([type])
}

model RecurringExpense {
  id            String        @id @default(cuid())
  title         String
  category      String
  amount        Decimal       @db.Decimal(12, 2)
  dayOfMonth    Int
  paymentStatus PaymentStatus @default(UNPAID)
  paidBy        String?
  notes         String?
  attachment    String?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model SalesSection {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  sales       Sale[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Sale {
  id              String        @id @default(cuid())
  customerId      String
  sectionId       String
  serviceTitle    String
  totalPrice      Decimal       @db.Decimal(12, 2)
  discount        Decimal       @default(0) @db.Decimal(12, 2)
  extraFees       Decimal       @default(0) @db.Decimal(12, 2)
  finalTotal      Decimal       @db.Decimal(12, 2)
  paidAmount      Decimal       @default(0) @db.Decimal(12, 2)
  remainingAmount Decimal       @db.Decimal(12, 2)
  projectCost     Decimal       @default(0) @db.Decimal(12, 2)
  netProfit       Decimal       @db.Decimal(12, 2)
  status          SaleStatus    @default(LEAD)
  deadline        DateTime?
  notes           String?
  customer        Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  section         SalesSection  @relation(fields: [sectionId], references: [id])
  payments        SalePayment[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([customerId])
  @@index([sectionId])
  @@index([status])
  @@index([deadline])
}

model SalePayment {
  id        String   @id @default(cuid())
  saleId    String
  amount    Decimal  @db.Decimal(12, 2)
  paidAt    DateTime @default(now())
  method    String?
  notes     String?
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model TeamMember {
  id        String        @id @default(cuid())
  name      String
  role      String
  phone     String?
  email     String?       @unique
  salary    Decimal       @default(0) @db.Decimal(12, 2)
  workType  WorkType
  startDate DateTime
  status    TeamStatus    @default(ACTIVE)
  notes     String?
  payments  TeamPayment[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model TeamPayment {
  id           String          @id @default(cuid())
  teamMemberId String
  type         TeamPaymentType
  amount       Decimal         @db.Decimal(12, 2)
  paidAt       DateTime        @default(now())
  notes        String?
  teamMember   TeamMember      @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  createdAt    DateTime        @default(now())
}

model WebsiteSyncLog {
  id         String     @id @default(cuid())
  customerId String?
  source     String     @default("website")
  status     SyncStatus
  message    String
  payload    Json
  customer   Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdAt  DateTime   @default(now())

  @@index([status])
  @@index([createdAt])
}

model Report {
  id        String   @id @default(cuid())
  name      String
  type      String
  filters   Json?
  data      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  actor     String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([entity])
  @@index([createdAt])
}

model ZktecoDevice {
  id          String              @id @default(cuid())
  name        String
  serialNumber String?            @unique @map("serial_number")
  ipAddress   String              @unique @map("ip_address")
  port        Int                 @default(4370)
  model       String?
  location    String?
  status      ZktecoDeviceStatus  @default(UNKNOWN)
  lastSeenAt  DateTime?           @map("last_seen_at")
  lastHeartbeatAt DateTime?       @map("last_heartbeat_at")
  users       ZktecoUser[]
  logs        ZktecoAttendanceLog[]
  syncBatches ZktecoSyncBatch[]
  employees   ZktecoEmployee[]
  commands    ZktecoDeviceCommand[]
  debugLogs   ZktecoDebugLog[]
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  @@index([serialNumber])
  @@index([status])
  @@map("zkteco_devices")
}

model ZktecoUser {
  id           String        @id @default(cuid())
  deviceId     String        @map("device_id")
  zktecoUserId String        @map("zkteco_user_id")
  name         String?
  cardNumber   String?       @map("card_number")
  privilege    String?
  rawPayload   Json?         @map("raw_payload")
  lastSyncedAt DateTime      @default(now()) @map("last_synced_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  device       ZktecoDevice  @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, zktecoUserId])
  @@index([zktecoUserId])
  @@index([name])
  @@map("zkteco_users")
}

model ZktecoAttendanceLog {
  id                  String            @id @default(cuid())
  deviceId            String            @map("device_id")
  zktecoUserId        String            @map("zkteco_user_id")
  employeeName        String?           @map("employee_name")
  attendanceTimestamp DateTime          @map("attendance_timestamp")
  punchType           String?           @map("punch_type")
  verifyType          String?           @map("verify_type")
  workCode            String?           @map("work_code")
  rawPayload          Json?             @map("raw_payload")
  syncBatchId         String?           @map("sync_batch_id")
  uniqueKey           String            @unique @map("unique_key")
  createdAt           DateTime          @default(now()) @map("created_at")
  device              ZktecoDevice      @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  syncBatch           ZktecoSyncBatch?  @relation(fields: [syncBatchId], references: [batchId], onDelete: SetNull)

  @@index([deviceId])
  @@index([zktecoUserId])
  @@index([attendanceTimestamp])
  @@index([syncBatchId])
  @@map("zkteco_attendance_logs")
}

model ZktecoEmployee {
  id           String        @id @default(cuid())
  deviceId     String?       @map("device_id")
  userId       String        @map("user_id")
  name         String?
  department   String?
  position     String?
  isActive     Boolean       @default(true) @map("is_active")
  rawPayload   Json?         @map("raw_payload")
  device       ZktecoDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@unique([deviceId, userId])
  @@index([userId])
  @@index([name])
  @@map("zkteco_employees")
}

model ZktecoDeviceCommand {
  id          String        @id @default(cuid())
  deviceId    String?       @map("device_id")
  commandCode String        @unique @map("command_code")
  command     String
  status      String        @default("PENDING")
  response    String?
  sentAt      DateTime?     @map("sent_at")
  completedAt DateTime?     @map("completed_at")
  device      ZktecoDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([deviceId])
  @@index([status])
  @@map("zkteco_device_commands")
}

model ZktecoDebugLog {
  id           String        @id @default(cuid())
  deviceId     String?       @map("device_id")
  serialNumber String?       @map("serial_number")
  method       String
  path         String
  queryParams  Json?         @map("query_params")
  headers      Json?
  rawBody      String?       @map("raw_body")
  responseBody String        @map("response_body")
  remoteAddress String?      @map("remote_address")
  device       ZktecoDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now()) @map("created_at")

  @@index([serialNumber])
  @@index([path])
  @@index([createdAt])
  @@map("zkteco_debug_logs")
}

model ZktecoSyncBatch {
  id                String               @id @default(cuid())
  deviceId          String               @map("device_id")
  batchId           String               @unique @map("batch_id")
  startedAt         DateTime             @map("started_at")
  finishedAt        DateTime?            @map("finished_at")
  status            ZktecoSyncStatus     @default(PENDING)
  logsFetched       Int                  @default(0) @map("logs_fetched")
  logsInserted      Int                  @default(0) @map("logs_inserted")
  duplicatesSkipped Int                  @default(0) @map("duplicates_skipped")
  usersFetched      Int                  @default(0) @map("users_fetched")
  usersInserted     Int                  @default(0) @map("users_inserted")
  errorCode         String?              @map("error_code")
  errorMessage      String?              @map("error_message")
  createdAt         DateTime             @default(now()) @map("created_at")
  device            ZktecoDevice         @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  logs              ZktecoAttendanceLog[]

  @@index([deviceId])
  @@index([status])
  @@index([startedAt])
  @@map("zkteco_sync_batches")
}

model CrmClient {
  id          String       @id @default(cuid())
  clientCode  String       @unique @map("client_code")
  name        String
  industry    String?
  location    String?
  phone       String?
  email       String?
  website     String?
  status      String       @default("ACTIVE")
  contacts    CrmContact[]
  leads       CrmLead[]
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@index([name])
  @@index([status])
  @@map("crm_clients")
}

model CrmContact {
  id        String    @id @default(cuid())
  clientId  String?   @map("client_id")
  name      String
  title     String?
  phone     String?
  email     String?
  whatsapp  String?
  client    CrmClient? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([phone])
  @@index([email])
  @@map("crm_contacts")
}

model CrmLead {
  id               String          @id @default(cuid())
  leadCode         String          @unique @map("lead_code")
  clientId         String?         @map("client_id")
  dateAdded        DateTime        @map("date_added")
  clientName       String          @map("client_name")
  contactPerson    String?         @map("contact_person")
  phone            String?
  email            String?
  whatsapp         String?
  instagramWebsite String?         @map("instagram_website")
  location         String?
  leadSource       String          @map("lead_source")
  industry         String?
  serviceRequired  String          @map("service_required")
  estimatedValue   Decimal         @default(0) @map("estimated_value") @db.Decimal(14, 2)
  priority         String
  status           String
  nextFollowUp     DateTime?       @map("next_follow_up")
  responsiblePerson String         @map("responsible_person")
  notes            String?
  createdBy        String          @map("created_by")
  client           CrmClient?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  deals            CrmDeal[]
  contactLogs      CrmContactLog[]
  meetings         CrmMeeting[]
  proposals        CrmProposal[]
  quotations       CrmQuotation[]
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  @@index([leadCode])
  @@index([status])
  @@index([priority])
  @@index([responsiblePerson])
  @@index([nextFollowUp])
  @@index([createdAt])
  @@map("crm_leads")
}

model CrmDeal {
  id                  String    @id @default(cuid())
  dealCode            String    @unique @map("deal_code")
  leadId              String?   @map("lead_id")
  leadCode            String    @map("lead_code")
  clientName          String    @map("client_name")
  serviceProject      String    @map("service_project")
  pipelineStage       String    @map("pipeline_stage")
  dealValue           Decimal   @default(0) @map("deal_value") @db.Decimal(14, 2)
  probability         Int       @default(10)
  expectedRevenue     Decimal   @default(0) @map("expected_revenue") @db.Decimal(14, 2)
  expectedClosingDate DateTime? @map("expected_closing_date")
  responsiblePerson   String    @map("responsible_person")
  status              String
  notes               String?
  lead                CrmLead?  @relation(fields: [leadId], references: [id], onDelete: SetNull)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@index([dealCode])
  @@index([leadCode])
  @@index([pipelineStage])
  @@index([status])
  @@index([responsiblePerson])
  @@index([expectedClosingDate])
  @@map("crm_deals")
}

model CrmContactLog {
  id                String    @id @default(cuid())
  contactLogCode    String    @unique @map("contact_log_code")
  leadId            String?   @map("lead_id")
  leadCode          String    @map("lead_code")
  clientName        String    @map("client_name")
  date              DateTime
  method            String
  discussionSummary String    @map("discussion_summary")
  nextAction        String    @map("next_action")
  nextFollowUp      DateTime? @map("next_follow_up")
  responsiblePerson String    @map("responsible_person")
  lead              CrmLead?  @relation(fields: [leadId], references: [id], onDelete: SetNull)
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([leadCode])
  @@index([date])
  @@index([nextFollowUp])
  @@index([responsiblePerson])
  @@map("crm_contact_logs")
}

model CrmMeeting {
  id                String    @id @default(cuid())
  meetingCode       String    @unique @map("meeting_code")
  leadId            String?   @map("lead_id")
  leadCode          String    @map("lead_code")
  clientName        String    @map("client_name")
  meetingDate       DateTime  @map("meeting_date")
  time              String
  location          String?
  meetingPurpose    String    @map("meeting_purpose")
  meetingStatus     String    @map("meeting_status")
  responsiblePerson String    @map("responsible_person")
  followUpRequired  String    @map("follow_up_required")
  notes             String?
  lead              CrmLead?  @relation(fields: [leadId], references: [id], onDelete: SetNull)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([leadCode])
  @@index([meetingDate])
  @@index([meetingStatus])
  @@index([responsiblePerson])
  @@map("crm_meetings")
}

model CrmProposal {
  id             String    @id @default(cuid())
  proposalCode   String    @unique @map("proposal_code")
  leadId         String?   @map("lead_id")
  leadCode       String    @map("lead_code")
  clientName     String    @map("client_name")
  projectService String    @map("project_service")
  proposalValue  Decimal   @default(0) @map("proposal_value") @db.Decimal(14, 2)
  dateSent       DateTime? @map("date_sent")
  validUntil     DateTime? @map("valid_until")
  status         String
  followUpDate   DateTime? @map("follow_up_date")
  attachmentUrl  String?   @map("attachment_url")
  notes          String?
  lead           CrmLead?  @relation(fields: [leadId], references: [id], onDelete: SetNull)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([leadCode])
  @@index([status])
  @@index([followUpDate])
  @@map("crm_proposals")
}

model CrmQuotation {
  id                 String    @id @default(cuid())
  quotationCode      String    @unique @map("quotation_code")
  leadId             String?   @map("lead_id")
  leadCode           String    @map("lead_code")
  clientName         String    @map("client_name")
  serviceItem        String    @map("service_item")
  amount             Decimal   @default(0) @db.Decimal(14, 2)
  dateSent           DateTime? @map("date_sent")
  validUntil         DateTime? @map("valid_until")
  status             String
  convertedToInvoice String    @default("No") @map("converted_to_invoice")
  attachmentUrl      String?   @map("attachment_url")
  notes              String?
  lead               CrmLead?  @relation(fields: [leadId], references: [id], onDelete: SetNull)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([leadCode])
  @@index([status])
  @@map("crm_quotations")
}

model CrmClosedDeal {
  id                String   @id @default(cuid())
  dealCode          String   @unique @map("deal_code")
  clientName        String   @map("client_name")
  serviceProject    String   @map("service_project")
  finalValue        Decimal  @default(0) @map("final_value") @db.Decimal(14, 2)
  closingDate       DateTime @map("closing_date")
  paymentStatus     String   @map("payment_status")
  projectStarted    String   @map("project_started")
  responsiblePerson String   @map("responsible_person")
  notes             String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([dealCode])
  @@index([closingDate])
  @@index([paymentStatus])
  @@index([responsiblePerson])
  @@map("crm_closed_deals")
}

model CrmLostDeal {
  id                String   @id @default(cuid())
  lostDealCode      String   @unique @map("lost_deal_code")
  clientName        String   @map("client_name")
  serviceProject    String   @map("service_project")
  estimatedValue    Decimal  @default(0) @map("estimated_value") @db.Decimal(14, 2)
  lostDate          DateTime @map("lost_date")
  reasonLost        String   @map("reason_lost")
  responsiblePerson String   @map("responsible_person")
  futureFollowUp    String   @map("future_follow_up")
  notes             String?
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([lostDealCode])
  @@index([lostDate])
  @@index([reasonLost])
  @@index([responsiblePerson])
  @@map("crm_lost_deals")
}

model CrmDailySalesActivity {
  id                 String   @id @default(cuid())
  date               DateTime
  salesperson        String
  callsMade          Int      @default(0) @map("calls_made")
  whatsappMessages   Int      @default(0) @map("whatsapp_messages")
  emailsSent         Int      @default(0) @map("emails_sent")
  meetingsScheduled  Int      @default(0) @map("meetings_scheduled")
  proposalsSent      Int      @default(0) @map("proposals_sent")
  quotationsSent     Int      @default(0) @map("quotations_sent")
  followUpsCompleted Int      @default(0) @map("follow_ups_completed")
  notes              String?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([date])
  @@index([salesperson])
  @@map("crm_daily_sales_activities")
}

model CrmWeeklySalesReport {
  id                         String   @id @default(cuid())
  weekFrom                   DateTime @map("week_from")
  weekTo                     DateTime @map("week_to")
  preparedBy                 String   @map("prepared_by")
  newLeadsAdded              Int      @default(0) @map("new_leads_added")
  clientsContacted           Int      @default(0) @map("clients_contacted")
  meetingsScheduled          Int      @default(0) @map("meetings_scheduled")
  meetingsCompleted          Int      @default(0) @map("meetings_completed")
  proposalsSent              Int      @default(0) @map("proposals_sent")
  quotationsSent             Int      @default(0) @map("quotations_sent")
  dealsApproved              Int      @default(0) @map("deals_approved")
  dealsClosedWon             Int      @default(0) @map("deals_closed_won")
  dealsClosedLost            Int      @default(0) @map("deals_closed_lost")
  totalExpectedPipelineValue Decimal  @default(0) @map("total_expected_pipeline_value") @db.Decimal(14, 2)
  totalClosedValue           Decimal  @default(0) @map("total_closed_value") @db.Decimal(14, 2)
  weeklySalesSummary         String?  @map("weekly_sales_summary")
  mainProblems               String?  @map("main_problems")
  nextWeekSalesPlan          String?  @map("next_week_sales_plan")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  @@index([weekFrom])
  @@index([weekTo])
  @@index([preparedBy])
  @@map("crm_weekly_sales_reports")
}

model CrmTargetClient {
  id                  String   @id @default(cuid())
  no                  Int
  companyClientName   String?  @map("company_client_name")
  industry            String
  location            String?
  contactPerson       String?  @map("contact_person")
  phone               String?
  instagramWebsite    String?  @map("instagram_website")
  serviceOpportunity  String   @map("service_opportunity")
  priority            String
  notes               String?
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([industry])
  @@index([priority])
  @@map("crm_target_clients")
}

model CrmSalesHandover {
  id                          String   @id @default(cuid())
  handoverCode                String   @unique @map("handover_code")
  clientName                  String   @map("client_name")
  projectService              String   @map("project_service")
  approvedValue               Decimal  @default(0) @map("approved_value") @db.Decimal(14, 2)
  paymentStatus               String   @map("payment_status")
  handoverDate                DateTime @map("handover_date")
  approvedScope               String   @map("approved_scope")
  clientRequirements          String?  @map("client_requirements")
  filesMaterialsReceived      Json?    @map("files_materials_received")
  operationsResponsiblePerson String   @map("operations_responsible_person")
  salesResponsiblePerson      String   @map("sales_responsible_person")
  salesSignature              String?  @map("sales_signature")
  operationsSignature         String?  @map("operations_signature")
  date                        DateTime
